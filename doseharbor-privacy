<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>DoseHarbor Privacy Policy</title>

  <style>
    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
      background: #f5f7fa;
      color: #1a1a1a;
      line-height: 1.6;
    }

    .container {
      max-width: 900px;
      margin: auto;
      padding: 40px 20px;
    }

    .card {
      background: #ffffff;
      padding: 40px;
      border-radius: 16px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    h1 {
      color: #0B1F3B;
      margin-bottom: 10px;
    }

    h2 {
      color: #0B1F3B;
      margin-top: 30px;
    }

    p {
      margin: 10px 0;
    }

    ul {
      padding-left: 20px;
    }

    li {
      margin-bottom: 8px;
    }

    .highlight {
      color: #2EC4B6;
      font-weight: 600;
    }

    .footer {
      margin-top: 40px;
      font-size: 14px;
      color: #666;
    }

    @media (max-width: 600px) {
      .card {
        padding: 25px;
      }
    }
